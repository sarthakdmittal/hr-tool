# ── Local development (SQLite, no DATABASE_URL needed) ──────────────────
PORT=5000
DB_PATH=./hr_tool.db
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ── Production (Render + Neon) ───────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/hr_tool?sslmode=require
# FRONTEND_URL=https://your-app.vercel.app
# RENDER_EXTERNAL_URL is set automatically by Render (used for keep-alive ping)
